# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saas_seeder
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Cookie Configuration
COOKIE_DOMAIN=localhost
# REQUIRED — generate with: php -r "echo bin2hex(random_bytes(32));"
COOKIE_ENCRYPTION_KEY=

# Password Security
# REQUIRED — generate with: php -r "echo bin2hex(random_bytes(32));"
PASSWORD_PEPPER=

# Application Environment (development | production)
APP_ENV=development

# JWT Configuration
# REQUIRED — generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET_KEY=
